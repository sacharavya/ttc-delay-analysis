    t = avl_row["first_sec"]

    # For trips near midnight (<7200 sec), also try +86400 (previous service day)
    if t < 7200:
        candidates["diff"] = candidates["gtfs_start_sec"].apply(
            lambda g: min(abs(g - t), abs(g - (t + 86400)))
        )
    else:
        candidates["diff"] = (candidates["gtfs_start_sec"] - t).abs()

    best = candidates.loc[candidates["diff"].idxmin()]

    results.append({
        "avl_trip_id":    avl_row["trip_id"],
        "avl_first_sec":  t,
        "avl_dir":        avl_row["inferred_dir"],
