AVL_COLS = ["date", "time_sec", "vehicle", "route", "run",
            "lat", "lon", "trip_id", "loading"]

def load_avl_route(route: str) -> pd.DataFrame:
    files = sorted((AVL_STOP / route).glob("*.csv"))
    chunks = []
    for f in files:
        df = pd.read_csv(f, header=None, names=AVL_COLS, dtype=str)
        df["_src_file"] = f.name
        chunks.append(df)
        print(f"  {f.name}  {len(df):>10,} rows")
    return pd.concat(chunks, ignore_index=True)

print("─── Route 29 ───")
