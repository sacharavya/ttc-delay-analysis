# ── Strategy ───────────────────────────────────────────────────────────────
# AVL has: trip_id, time_sec, lat, lon (per ping — NOT per stop)
# GTFS has: trip_id, stop_id, stop_sequence, arrival_sec, lat/lon (from stops)
#
# The AVL pings are GPS traces, not stop-events. To get delay at each stop:
#   1. Join stops lat/lon onto gtfs_st
#   2. For each AVL ping (trip_id, time_sec, lat, lon):
#      → find the closest scheduled stop (by distance)
#      → delay = time_sec − arrival_sec at that stop
#
# This is expensive for 200M+ rows. We use a chunked spatial approach.
# But FIRST — check if the AVL already has a stop field.

print("AVL columns:", list(avl.columns))
print()
# If there's a 'Stop' or 'stop_id' column, the match is MUCH simpler — 
# direct join on (trip_id, stop_id) without any spatial math.
# Check below:
if "stop_id" in avl.columns or "stop" in [c.lower() for c in avl.columns]:
    print("✓ AVL has a stop field — can do direct join on (trip_id, stop_id)")
else:
    print("✗ No stop field — will need spatial nearest-stop matching")


import numpy as np

# ── Join stop coordinates onto stop_times ──────────────────────────────────
# gtfs_st has trip_id, stop_id, stop_sequence, arrival_sec
# gtfs_stops has stop_id, stop_lat, stop_lon

gtfs_stops["stop_lat"] = pd.to_numeric(gtfs_stops["stop_lat"], errors="coerce")
gtfs_stops["stop_lon"] = pd.to_numeric(gtfs_stops["stop_lon"], errors="coerce")
gtfs_st["arrival_sec"] = pd.to_numeric(gtfs_st["arrival_sec"], errors="coerce")
gtfs_st["stop_sequence"] = pd.to_numeric(gtfs_st["stop_sequence"], errors="coerce")

sched = gtfs_st.merge(
    gtfs_stops[["stop_id", "stop_lat", "stop_lon", "stop_name"]],
    on="stop_id", how="left"
)

print(f"sched rows: {len(sched):,}")
print(f"Null stop_lat: {sched['stop_lat'].isna().sum():,}")
print(sched[["trip_id","stop_id","stop_sequence","arrival_sec","stop_lat","stop_lon"]].head(5).to_string())


