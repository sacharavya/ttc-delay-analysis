# ── Step 1: Filter to good matches only (diff < 5 min) ────────────────────
good_matches = matches_dedup[matches_dedup["diff_min"] < 5].copy()
print(f"Good matches (diff<5min): {len(good_matches)} trips  ({len(good_matches)/len(matches_dedup)*100:.1f}%)")
print(f"Discarded (diff≥5min):    {len(matches_dedup)-len(good_matches)} trips")

# ── Step 2: Build GTFS schedule for matched trips only ─────────────────────
matched_gtfs_ids = set(good_matches["gtfs_trip_id"].unique())

trip_sched = sched[sched["trip_id"].isin(matched_gtfs_ids)].copy()
trip_sched["arrival_sec"] = pd.to_numeric(trip_sched["arrival_sec"], errors="coerce")
print(f"\\nScheduled stop-events for matched trips: {len(trip_sched):,}")

# ── Step 3: Build AVL pings for matched trips ──────────────────────────────
# Map avl_trip_id → gtfs_trip_id from good_matches
avl_to_gtfs = dict(zip(good_matches["avl_trip_id"], good_matches["gtfs_trip_id"]))

avl_work = avl_jan1_29[avl_jan1_29["trip_id"].isin(avl_to_gtfs.keys())].copy()
avl_work["gtfs_trip_id"] = avl_work["trip_id"].map(avl_to_gtfs)

# Adjust time_sec for midnight-crossing trips (where first_sec < 7200)
midnight_trip_ids = set(good_matches[good_matches["avl_first_sec"] < 7200]["avl_trip_id"])
avl_work["time_sec_adj"] = avl_work.apply(
    lambda r: r["time_sec"] + 86400 if r["trip_id"] in midnight_trip_ids else r["time_sec"],
    axis=1
)

print(f"AVL pings to process: {len(avl_work):,}")

# ── Step 4: Spatial match — nearest scheduled stop per ping ───────────────
from tqdm.auto import tqdm

results = []
sched_by_trip = trip_sched.set_index("trip_id")

for gtfs_id, ping_grp in tqdm(avl_work.groupby("gtfs_trip_id"), desc="Matching pings to stops"):
    try:
        stops_for_trip = sched_by_trip.loc[[gtfs_id]].dropna(subset=["stop_lat","stop_lon","arrival_sec"])
    except KeyError:
        continue
    if stops_for_trip.empty:
        continue

    s_lat = stops_for_trip["stop_lat"].values
    s_lon = stops_for_trip["stop_lon"].values
    s_arr = stops_for_trip["arrival_sec"].values
    s_sid = stops_for_trip["stop_id"].values
    s_seq = stops_for_trip["stop_sequence"].values

    p_lat = ping_grp["lat"].values
    p_lon = ping_grp["lon"].values
    p_t   = ping_grp["time_sec_adj"].values

    # Distance matrix (n_pings × n_stops)
    dist_m = haversine_m(p_lat[:,None], p_lon[:,None], s_lat[None,:], s_lon[None,:])
    nearest = dist_m.argmin(axis=1)

    grp_out = ping_grp.copy()
    grp_out["matched_stop_id"]   = s_sid[nearest]
    grp_out["matched_stop_seq"]  = s_seq[nearest]
    grp_out["sched_arrival_sec"] = s_arr[nearest]
    grp_out["dist_to_stop_m"]    = dist_m[np.arange(len(ping_grp)), nearest]
    grp_out["delay_sec"]         = p_t - s_arr[nearest]
    grp_out["delay_min"]         = grp_out["delay_sec"] / 60
    results.append(grp_out)

delay_df = pd.concat(results, ignore_index=True)
print(f"\\nTotal pings with delay computed: {len(delay_df):,}")

# ── Step 5: Quality filter ─────────────────────────────────────────────────
delay_clean = delay_df[
    (delay_df["dist_to_stop_m"] <= 150) &
    (delay_df["delay_min"].between(-30, 90))
].copy()

print(f"After quality filter (dist≤150m, delay -30 to +90 min): {len(delay_clean):,}")

print("\\n── Delay distribution (minutes) ──")
print(delay_clean["delay_min"].describe(
    percentiles=[.05,.25,.5,.75,.95]).round(2).to_string())

print("\\n── Distance to matched stop ──")
print(pd.cut(delay_df["dist_to_stop_m"],
             bins=[0,50,100,150,300,1000,np.inf],
             labels=["0-50m","50-100m","100-150m","150-300m","300m-1km",">1km"]
            ).value_counts().sort_index().to_string())


# ── Rethink: compute ONE delay per stop per trip, not per ping ─────────────
# For each (gtfs_trip_id, matched_stop_id): 
#   take the ping that was CLOSEST to that stop (min dist)
#   that ping's delay = the bus arrival delay at that stop

stop_level_delay = (
    delay_df
    .sort_values("dist_to_stop_m")
    .groupby(["gtfs_trip_id", "matched_stop_id", "matched_stop_seq"])
    .agg(
        best_dist_m      = ("dist_to_stop_m", "min"),
        delay_at_stop_sec= ("delay_sec",      "first"),   # from the closest ping
        delay_at_stop_min= ("delay_min",      "first"),
        n_pings_near_stop= ("dist_to_stop_m", "count"),
        avl_trip_id      = ("trip_id",        "first"),
        vehicle          = ("vehicle",        "first"),
    )
    .reset_index()
)

# Keep only stops where best ping was within 150m
stop_level_delay = stop_level_delay[stop_level_delay["best_dist_m"] <= 150].copy()

print(f"Stop-level delay records: {len(stop_level_delay):,}")
print(f"Unique trips:             {stop_level_delay['gtfs_trip_id'].nunique()}")
print(f"Avg stops per trip:       {len(stop_level_delay)/stop_level_delay['gtfs_trip_id'].nunique():.1f}")

print("\\n── Delay at stop (minutes) ──")
print(stop_level_delay["delay_at_stop_min"].describe(
    percentiles=[.05,.25,.5,.75,.95]).round(2).to_string())

print("\\n── Distance of best ping to stop (metres) ──")
print(stop_level_delay["best_dist_m"].describe(
    percentiles=[.25,.5,.75,.95]).round(1).to_string())

# How many stops per trip are we capturing?
stops_per_trip = stop_level_delay.groupby("gtfs_trip_id")["matched_stop_id"].count()
print(f"\\nStops captured per trip:")
print(stops_per_trip.describe(percentiles=[.1,.25,.5,.75,.9]).round(1).to_string())

# Compare to scheduled stops per trip
sched_stops_per_trip = trip_sched.groupby("trip_id")["stop_id"].count()
median_sched = sched_stops_per_trip.median()
print(f"\\nMedian scheduled stops per GTFS trip: {median_sched:.0f}")
print(f"Median captured stops per AVL trip:    {stops_per_trip.median():.0f}")
print(f"Coverage: {stops_per_trip.median()/median_sched*100:.1f}%")


# ── Step 1: Deduplicate GTFS stop_times ───────────────────────────────────
# The merged GTFS has the same stop-times from multiple feed versions.
# Keep one row per (trip_id, stop_sequence) — the most recent feed's version.

print("Before dedup:", len(gtfs_st))

if "_feed_date" in gtfs_st.columns:
    gtfs_st_dedup = (
        gtfs_st
        .sort_values("_feed_date", ascending=False)
        .drop_duplicates(subset=["trip_id","stop_sequence"], keep="first")
    )
else:
    gtfs_st_dedup = gtfs_st.drop_duplicates(subset=["trip_id","stop_sequence"], keep="first")

gtfs_st_dedup["arrival_sec"]   = pd.to_numeric(gtfs_st_dedup["arrival_sec"],   errors="coerce")
gtfs_st_dedup["departure_sec"] = pd.to_numeric(gtfs_st_dedup["departure_sec"], errors="coerce")
gtfs_st_dedup["stop_sequence"] = pd.to_numeric(gtfs_st_dedup["stop_sequence"], errors="coerce")

print(f"After  dedup: {len(gtfs_st_dedup):,}")

# Rebuild sched with deduped stop_times
sched_dedup = gtfs_st_dedup.merge(
    gtfs_stops[["stop_id","stop_lat","stop_lon","stop_name"]],
    on="stop_id", how="left"
)
sched_dedup["stop_lat"] = pd.to_numeric(sched_dedup["stop_lat"], errors="coerce")
sched_dedup["stop_lon"] = pd.to_numeric(sched_dedup["stop_lon"], errors="coerce")

print(f"sched_dedup rows: {len(sched_dedup):,}")

# Check stops per trip now
stops_per_trip_check = sched_dedup[sched_dedup["trip_id"].isin(list(matched_gtfs_ids)[:5])].groupby("trip_id")["stop_id"].count()
print("\\nStops per trip (sample 5):")
print(stops_per_trip_check.to_string())


# ── Time-constrained nearest-stop match ───────────────────────────────────
# For each AVL ping: find stops on its matched GTFS trip where
#   |scheduled_arrival - ping_time| <= TIME_WINDOW_SEC
# Then among those candidates, pick the spatially closest one.
# This prevents assigning a ping to a stop scheduled hours away.

TIME_WINDOW_SEC = 600   # ±10 minutes

results2 = []
sched_by_trip2 = sched_dedup.set_index("trip_id")

trip_sched2 = sched_dedup[sched_dedup["trip_id"].isin(matched_gtfs_ids)].copy()
sched_by_trip2 = trip_sched2.set_index("trip_id")

skipped = 0
for gtfs_id, ping_grp in avl_work.groupby("gtfs_trip_id"):
    try:
        stops = sched_by_trip2.loc[[gtfs_id]].dropna(subset=["stop_lat","stop_lon","arrival_sec"])
    except KeyError:
        skipped += 1
        continue
    if stops.empty:
        skipped += 1
        continue

    s_lat = stops["stop_lat"].values
    s_lon = stops["stop_lon"].values
    s_arr = stops["arrival_sec"].values
    s_sid = stops["stop_id"].values
    s_seq = stops["stop_sequence"].values

    p_lat = ping_grp["lat"].values
    p_lon = ping_grp["lon"].values
    p_t   = ping_grp["time_sec_adj"].values

    rows = []
    for i in range(len(ping_grp)):
        # Time-constrained candidates
        time_ok = np.abs(s_arr - p_t[i]) <= TIME_WINDOW_SEC
        if not time_ok.any():
            continue  # ping too far from any scheduled stop time — skip

        cand_lat = s_lat[time_ok]
        cand_lon = s_lon[time_ok]
        cand_arr = s_arr[time_ok]
        cand_sid = s_sid[time_ok]
        cand_seq = s_seq[time_ok]

        dists = haversine_m(p_lat[i], p_lon[i], cand_lat, cand_lon)
        best  = dists.argmin()

        rows.append({
            "gtfs_trip_id":      gtfs_id,
            "avl_trip_id":       ping_grp["trip_id"].iloc[i],
            "vehicle":           ping_grp["vehicle"].iloc[i],
            "date":              ping_grp["date"].iloc[i],
            "time_sec":          p_t[i],
            "lat":               p_lat[i],
            "lon":               p_lon[i],
            "loading":           ping_grp["loading"].iloc[i],
            "matched_stop_id":   cand_sid[best],
            "matched_stop_seq":  cand_seq[best],
            "sched_arrival_sec": cand_arr[best],
            "dist_to_stop_m":    dists[best],
            "delay_sec":         p_t[i] - cand_arr[best],
            "delay_min":         (p_t[i] - cand_arr[best]) / 60,
        })

    if rows:
        results2.append(pd.DataFrame(rows))

print(f"Skipped trips (no sched): {skipped}")
delay2 = pd.concat(results2, ignore_index=True)
print(f"Total pings matched: {len(delay2):,}")

# ── Aggregate to one delay per stop per trip ──────────────────────────────
stop_delay2 = (
    delay2
    .sort_values("dist_to_stop_m")
    .drop_duplicates(subset=["gtfs_trip_id","matched_stop_id"], keep="first")
    .copy()
)
stop_delay2 = stop_delay2[stop_delay2["dist_to_stop_m"] <= 150]

print(f"\\nStop-level delay records: {len(stop_delay2):,}")
print(f"Unique trips:             {stop_delay2['gtfs_trip_id'].nunique()}")
print(f"Avg stops per trip:       {len(stop_delay2)/stop_delay2['gtfs_trip_id'].nunique():.1f}")

print("\\n── Delay at stop (minutes) ──")
print(stop_delay2["delay_min"].describe(
    percentiles=[.05,.25,.5,.75,.95]).round(2).to_string())


# ── Sequence-constrained stop matching ────────────────────────────────────
# For each GTFS trip:
#   For each scheduled stop (in order):
#     Find AVL pings that occurred between prev_stop_sched and next_stop_sched + buffer
#     Among those, pick the ping spatially closest to the stop
#
# This handles any magnitude of delay because we use stop ORDER not clock time.

HEADWAY_BUFFER_SEC = 300   # 5 min buffer beyond next stop's scheduled time

results3 = []
skipped3 = 0

for gtfs_id, ping_grp in avl_work.groupby("gtfs_trip_id"):
    try:
        stops = sched_by_trip2.loc[[gtfs_id]].dropna(
            subset=["stop_lat","stop_lon","arrival_sec","stop_sequence"]
        ).sort_values("stop_sequence").reset_index(drop=True)
    except KeyError:
        skipped3 += 1
        continue
    if len(stops) < 2:
        skipped3 += 1
        continue

    pings = ping_grp.sort_values("time_sec_adj").reset_index(drop=True)
    p_t   = pings["time_sec_adj"].values
    p_lat = pings["lat"].values
    p_lon = pings["lon"].values

    n_stops = len(stops)
    stop_rows = []

    for si in range(n_stops):
        s_arr = stops["arrival_sec"].iloc[si]
        s_lat = stops["stop_lat"].iloc[si]
        s_lon = stops["stop_lon"].iloc[si]
        s_sid = stops["stop_id"].iloc[si]
        s_seq = stops["stop_sequence"].iloc[si]

        # Time window: from previous stop's sched time to next stop's sched time + buffer
        t_lo = stops["arrival_sec"].iloc[si-1] if si > 0 else s_arr - 1800
        t_hi = stops["arrival_sec"].iloc[si+1] + HEADWAY_BUFFER_SEC if si < n_stops-1 else s_arr + 1800

        mask = (p_t >= t_lo) & (p_t <= t_hi)
        if not mask.any():
            continue

        cand_lat = p_lat[mask]
        cand_lon = p_lon[mask]
        cand_t   = p_t[mask]

        dists = haversine_m(s_lat, s_lon, cand_lat, cand_lon)
        best  = dists.argmin()

        stop_rows.append({
            "gtfs_trip_id":      gtfs_id,
            "avl_trip_id":       pings["trip_id"].iloc[0],
            "vehicle":           pings["vehicle"].iloc[0],
            "date":              pings["date"].iloc[0],
            "matched_stop_id":   s_sid,
            "matched_stop_seq":  s_seq,
            "sched_arrival_sec": s_arr,
            "actual_time_sec":   cand_t[best],
            "dist_to_stop_m":    dists[best],
            "delay_sec":         cand_t[best] - s_arr,
            "delay_min":         (cand_t[best] - s_arr) / 60,
            "loading":           pings["loading"].iloc[0],
        })

    if stop_rows:
        results3.append(pd.DataFrame(stop_rows))

print(f"Skipped: {skipped3}")
stop_delay3 = pd.concat(results3, ignore_index=True)

# Filter out stops where best ping was too far away (bus never actually passed)
stop_delay3 = stop_delay3[stop_delay3["dist_to_stop_m"] <= 150].copy()

print(f"\\nStop-level records:   {len(stop_delay3):,}")
print(f"Unique trips:         {stop_delay3['gtfs_trip_id'].nunique()}")
print(f"Avg stops per trip:   {len(stop_delay3)/stop_delay3['gtfs_trip_id'].nunique():.1f}")

print("\\n── Delay at stop (minutes) ──")
print(stop_delay3["delay_min"].describe(
    percentiles=[.05,.25,.5,.75,.95]).round(2).to_string())

print("\\n── Distance to stop ──")
print(pd.cut(stop_delay3["dist_to_stop_m"],
    bins=[0,25,50,100,150],
    labels=["0-25m","25-50m","50-100m","100-150m"]
).value_counts().sort_index().to_string())


