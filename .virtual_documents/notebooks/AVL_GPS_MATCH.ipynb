# ── Vectorised Haversine (returns metres) ─────────────────────────────────
def haversine_m(lat1, lon1, lat2, lon2):
    R = 6_371_000  # Earth radius in metres
    phi1, phi2 = np.radians(lat1), np.radians(lat2)
    dphi  = np.radians(lat2 - lat1)
    dlam  = np.radians(lon2 - lon1)
    a = np.sin(dphi/2)**2 + np.cos(phi1)*np.cos(phi2)*np.sin(dlam/2)**2
    return 2 * R * np.arcsin(np.sqrt(a))


from tqdm.auto import tqdm

# ── Work only on rows with a matched trip_id ─────────────────────────────
avl_work = avl[avl["trip_id"].isin(matched)].copy()
avl_work["trip_id"] = avl_work["trip_id"].astype(str)
sched_idx = sched.set_index("trip_id")

results = []

for trip_id, grp in tqdm(avl_work.groupby("trip_id"), desc="Matching trips"):
    # Get the scheduled stops for this trip
    try:
        trip_sched = sched_idx.loc[[trip_id]].dropna(subset=["stop_lat","stop_lon","arrival_sec"])
    except KeyError:
        continue
    if trip_sched.empty:
        continue

    sched_lat = trip_sched["stop_lat"].values
    sched_lon = trip_sched["stop_lon"].values
    sched_arr = trip_sched["arrival_sec"].values
    sched_sid = trip_sched["stop_id"].values
    sched_seq = trip_sched["stop_sequence"].values

    # For each AVL ping in this trip, find nearest stop
    avl_lat = grp["lat"].values
    avl_lon = grp["lon"].values
    avl_t   = grp["time_sec"].values

    # Matrix: (n_pings × n_stops)
    dist_m = haversine_m(
        avl_lat[:, None], avl_lon[:, None],
        sched_lat[None, :], sched_lon[None, :]
    )
    nearest_idx = dist_m.argmin(axis=1)

    grp = grp.copy()
    grp["matched_stop_id"]  = sched_sid[nearest_idx]
    grp["matched_stop_seq"] = sched_seq[nearest_idx]
    grp["sched_arrival_sec"]= sched_arr[nearest_idx]
    grp["dist_to_stop_m"]   = dist_m[np.arange(len(grp)), nearest_idx]
    grp["delay_sec"]        = avl_t - sched_arr[nearest_idx]
    grp["delay_min"]        = grp["delay_sec"] / 60

    results.append(grp)

matched_df = pd.concat(results, ignore_index=True)
print(f"\\nMatched rows: {len(matched_df):,}")
print(matched_df[["date","time_hhmm","route","trip_id","matched_stop_id",
                   "dist_to_stop_m","sched_arrival_sec","delay_min"]].head(10).to_string())


# ── Flag & filter ─────────────────────────────────────────────────────────
# A ping matched to a stop >150m away is likely between stops (mid-block GPS)
# Delay outside ±90 min is almost certainly a data/matching error

DIST_THRESHOLD_M  = 150   # metres — discard pings too far from any stop
DELAY_MIN_LO      = -30   # minutes — more than 30 early = likely wrong trip match
DELAY_MIN_HI      = 90    # minutes — more than 90 late = likely data error

before = len(matched_df)

matched_df["dist_ok"]  = matched_df["dist_to_stop_m"] <= DIST_THRESHOLD_M
matched_df["delay_ok"] = matched_df["delay_min"].between(DELAY_MIN_LO, DELAY_MIN_HI)

print("── Distance to matched stop ──")
print(pd.cut(matched_df["dist_to_stop_m"],
             bins=[0,50,100,150,300,1000,np.inf],
             labels=["0-50m","50-100m","100-150m","150-300m","300m-1km",">1km"]
            ).value_counts().sort_index().to_string())

print("\\n── Delay distribution (all matched pings, minutes) ──")
print(matched_df["delay_min"].describe(
    percentiles=[.01,.05,.25,.5,.75,.95,.99]).round(2).to_string())

clean = matched_df[matched_df["dist_ok"] & matched_df["delay_ok"]].copy()
print(f"\\nRows kept after quality filter: {len(clean):,}  ({len(clean)/before*100:.1f}%)")
print(f"Rows removed (far from stop):   {(~matched_df['dist_ok']).sum():,}")
print(f"Rows removed (extreme delay):   {(matched_df['dist_ok'] & ~matched_df['delay_ok']).sum():,}")


