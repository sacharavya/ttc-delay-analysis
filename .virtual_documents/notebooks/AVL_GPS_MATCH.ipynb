# ── Match AVL trips to GTFS trips: direction + start time + midnight fix ───

results = []

for _, avl_row in trip_summary.iterrows():
    candidates = gtfs_trip_start[
        gtfs_trip_start["direction_id"] == avl_row["inferred_dir"]
    ].copy()
    if candidates.empty:
