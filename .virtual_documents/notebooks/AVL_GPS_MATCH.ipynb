        "run":            avl_row["run"],
        "n_pings":        avl_row["n_pings"],
        "duration_min":   avl_row["duration_min"],
        "gtfs_trip_id":   best["trip_id"],
        "gtfs_start_sec": best["gtfs_start_sec"],
        "diff_sec":       best["diff"],
        "diff_min":       best["diff"] / 60,
    })

matches = pd.DataFrame(results)

