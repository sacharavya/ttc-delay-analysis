# ── Full-year pipeline — Route 29 & 39, Jan–Dec 2025 ─────────────────────
import gc
from pathlib import Path

OUT_DIR = ROOT / "data" / "processed" / "stop_delays"
OUT_DIR.mkdir(parents=True, exist_ok=True)

# ── GTFS feed selection per date ───────────────────────────────────────────
# Pre-build three separate GTFS schedule tables, one per feed period

def build_sched_for_feed(feed_date: str) -> pd.DataFrame:
    """Build deduplicated stop_times+stops for a specific feed date."""
    st = gtfs_st[gtfs_st.get("_feed_date", pd.Series([feed_date]*len(gtfs_st))) == feed_date].copy() if "_feed_date" in gtfs_st.columns else gtfs_st.copy()
    trips_fd = gtfs_trips[gtfs_trips.get("_feed_date", pd.Series([feed_date]*len(gtfs_trips))) == feed_date].copy() if "_feed_date" in gtfs_trips.columns else gtfs_trips.copy()

    st = st.drop_duplicates(subset=["trip_id","stop_sequence"], keep="first")
    st["arrival_sec"]    = pd.to_numeric(st["arrival_sec"],    errors="coerce")
    st["departure_sec"]  = pd.to_numeric(st["departure_sec"],  errors="coerce")
    st["stop_sequence"]  = pd.to_numeric(st["stop_sequence"],  errors="coerce")

    sched = st.merge(
        gtfs_stops[["stop_id","stop_lat","stop_lon","stop_name"]],
        on="stop_id", how="left"
    )
    sched["stop_lat"] = pd.to_numeric(sched["stop_lat"], errors="coerce")
    sched["stop_lon"] = pd.to_numeric(sched["stop_lon"], errors="coerce")
    return sched, trips_fd

print("Building GTFS schedule tables per feed period...")
sched_p1, trips_p1 = build_sched_for_feed("2025-02-28")  # Jan 1 – Aug 28
sched_p2, trips_p2 = build_sched_for_feed("2025-08-29")  # Aug 29 – Nov 12
sched_p3, trips_p3 = build_sched_for_feed("2025-11-13")  # Nov 13 – Dec 31

print(f"Period 1 (to Aug 28):   {len(sched_p1):,} stop-times")
print(f"Period 2 (Aug 29-Nov 12): {len(sched_p2):,} stop-times")
print(f"Period 3 (Nov 13+):     {len(sched_p3):,} stop-times")

def get_sched_and_trips(date: pd.Timestamp):
    ds = date.strftime("%Y-%m-%d")
    if ds < "2025-08-29":
        return sched_p1, trips_p1
    elif ds < "2025-11-13":
        return sched_p2, trips_p2
    else:
        return sched_p3, trips_p3


# ── Core matching function (reusable per day) ──────────────────────────────

HEADWAY_BUFFER_SEC = 300

def match_day(avl_day: pd.DataFrame, route: str, date: pd.Timestamp) -> pd.DataFrame:
    """
    Full pipeline for one route, one day:
    1. Infer trip direction from lat movement
    2. Match AVL trips to GTFS trips by direction + start time
    3. Sequence-constrained stop matching
    4. Return stop-level delay records
    """
    if avl_day.empty:
        return pd.DataFrame()

    sched_fd, trips_fd = get_sched_and_trips(date)

    # Active service_ids for this date
    dow = date.strftime("%A").lower()
    date_str = date.strftime("%Y%m%d")

    cal = gtfs_cal.copy()
    active_sids = set(
        cal[(cal["start_date"] <= date_str) &
            (cal["end_date"]   >= date_str) &
            (cal[dow]          == "1")]["service_id"].astype(str)
    )
    # calendar_dates exceptions
    if "_feed_date" in gtfs_cd.columns:
        cd = gtfs_cd[gtfs_cd["_feed_date"] == date.strftime("%Y-%m-%d")]
    else:
        cd = gtfs_cd
    added   = set(cd[(cd["date"]==date_str) & (cd["exception_type"]=="1")]["service_id"].astype(str))
    removed = set(cd[(cd["date"]==date_str) & (cd["exception_type"]=="2")]["service_id"].astype(str))
    active_sids = (active_sids | added) - removed

    # GTFS trips for this route on this date
    gtfs_route_trips = trips_fd[
        (trips_fd["route_id"] == route) &
        (trips_fd["service_id"].astype(str).isin(active_sids))
    ]
    if gtfs_route_trips.empty:
        return pd.DataFrame()

    gtfs_ids = set(gtfs_route_trips["trip_id"].unique())

    # GTFS trip start times
    gtfs_starts = (
        sched_fd[sched_fd["trip_id"].isin(gtfs_ids)]
        .sort_values("stop_sequence")
        .groupby("trip_id")["departure_sec"].first()
        .reset_index().rename(columns={"departure_sec":"gtfs_start_sec"})
        .merge(gtfs_route_trips[["trip_id","direction_id"]], on="trip_id", how="left")
    )
    gtfs_starts["direction_id"] = gtfs_starts["direction_id"].astype(str)

    # AVL trip summaries
    trip_sum = avl_day.groupby("trip_id").agg(
        first_sec   = ("time_sec", "min"),
        lat_first   = ("lat", "first"),
        lat_last    = ("lat", "last"),
    ).reset_index()
    trip_sum["inferred_dir"] = (trip_sum["lat_last"] > trip_sum["lat_first"]).astype(int).astype(str)
    midnight_trips = set(trip_sum[trip_sum["first_sec"] < 7200]["trip_id"])

    # Match AVL → GTFS
    avl_to_gtfs = {}
    for _, row in trip_sum.iterrows():
        cands = gtfs_starts[gtfs_starts["direction_id"] == row["inferred_dir"]].copy()
        if cands.empty:
            continue
        t = row["first_sec"]
        if t < 7200:
            cands["diff"] = cands["gtfs_start_sec"].apply(lambda g: min(abs(g-t), abs(g-(t+86400))))
        else:
            cands["diff"] = (cands["gtfs_start_sec"] - t).abs()
        best = cands.loc[cands["diff"].idxmin()]
        if best["diff"] / 60 < 5:  # only accept matches within 5 min
            avl_to_gtfs[row["trip_id"]] = best["trip_id"]

    if not avl_to_gtfs:
        return pd.DataFrame()

    # Prepare AVL pings
    avl_work_d = avl_day[avl_day["trip_id"].isin(avl_to_gtfs)].copy()
    avl_work_d["gtfs_trip_id"] = avl_work_d["trip_id"].map(avl_to_gtfs)
    avl_work_d["time_sec_adj"] = avl_work_d.apply(
        lambda r: r["time_sec"] + 86400 if r["trip_id"] in midnight_trips else r["time_sec"], axis=1
    )

    # Sequence-constrained stop matching
    sched_day = sched_fd[sched_fd["trip_id"].isin(set(avl_to_gtfs.values()))].copy()
    sched_by_t = sched_day.set_index("trip_id")

    results = []
    for gtfs_id, ping_grp in avl_work_d.groupby("gtfs_trip_id"):
        try:
            stops = sched_by_t.loc[[gtfs_id]].dropna(
                subset=["stop_lat","stop_lon","arrival_sec","stop_sequence"]
            ).sort_values("stop_sequence").reset_index(drop=True)
        except KeyError:
            continue
        if len(stops) < 2:
            continue

        pings = ping_grp.sort_values("time_sec_adj").reset_index(drop=True)
        p_t   = pings["time_sec_adj"].values
        p_lat = pings["lat"].values
        p_lon = pings["lon"].values
        n_stops = len(stops)

        for si in range(n_stops):
            s_arr = stops["arrival_sec"].iloc[si]
            s_lat = stops["stop_lat"].iloc[si]
            s_lon = stops["stop_lon"].iloc[si]
            t_lo  = stops["arrival_sec"].iloc[si-1] if si > 0 else s_arr - 1800
            t_hi  = stops["arrival_sec"].iloc[si+1] + HEADWAY_BUFFER_SEC if si < n_stops-1 else s_arr + 1800

            mask = (p_t >= t_lo) & (p_t <= t_hi)
            if not mask.any():
                continue

            dists = haversine_m(s_lat, s_lon, p_lat[mask], p_lon[mask])
            best  = dists.argmin()
            if dists[best] > 150:
                continue

            results.append({
                "date":              date,
                "route":             route,
                "gtfs_trip_id":      gtfs_id,
                "avl_trip_id":       pings["trip_id"].iloc[0],
                "vehicle":           pings["vehicle"].iloc[0],
                "stop_id":           stops["stop_id"].iloc[si],
                "stop_sequence":     stops["stop_sequence"].iloc[si],
                "sched_arrival_sec": s_arr,
                "actual_time_sec":   p_t[mask][best],
                "dist_to_stop_m":    dists[best],
                "delay_sec":         p_t[mask][best] - s_arr,
                "delay_min":         (p_t[mask][best] - s_arr) / 60,
                "loading":           pings["loading"].iloc[0],
            })

    return pd.DataFrame(results)


# ── Run full year — one month at a time, save to parquet ──────────────────
from tqdm.auto import tqdm

ROUTES = ["29", "39"]

for route in ROUTES:
    print(f"\\n{'='*50}")
    print(f"Processing route {route}...")
    files = sorted((AVL_STOP / route).glob("*.csv"))

    for f in files:
        month_str = f.stem.split("_")[0]  # e.g. '202501'
        out_file  = OUT_DIR / f"delays_rt{route}_{month_str}.parquet"

        if out_file.exists():
            print(f"  {f.name} — already done, skipping")
            continue

        print(f"  Loading {f.name}...")
        month_avl = pd.read_csv(f, header=None, names=AVL_COLS, dtype=str)
        month_avl["date"]     = pd.to_datetime(month_avl["date"], format="%Y%m%d", errors="coerce")
        month_avl["time_sec"] = pd.to_numeric(month_avl["time_sec"], errors="coerce")
        month_avl["lat"]      = pd.to_numeric(month_avl["lat"],      errors="coerce")
        month_avl["lon"]      = pd.to_numeric(month_avl["lon"],      errors="coerce")
        month_avl = month_avl[month_avl["route"] == route].dropna(subset=["date","lat","lon"])

        dates = sorted(month_avl["date"].dropna().unique())
        month_results = []

        for date in tqdm(dates, desc=f"rt{route} {month_str}"):
            day_avl = month_avl[month_avl["date"] == date].copy()
            day_df  = match_day(day_avl, route, pd.Timestamp(date))
            if not day_df.empty:
                month_results.append(day_df)

        if month_results:
            month_df = pd.concat(month_results, ignore_index=True)
            month_df.to_parquet(out_file, index=False)
            print(f"    → {len(month_df):,} stop-delay records saved to {out_file.name}")
        else:
            print(f"    → No results for {month_str}")

        del month_avl, month_results
        gc.collect()

print("\\nDone. Combining all months...")
all_files = sorted(OUT_DIR.glob("delays_rt*.parquet"))
delays_all = pd.concat([pd.read_parquet(f) for f in all_files], ignore_index=True)
delays_all.to_parquet(OUT_DIR / "delays_all_routes_2025.parquet", index=False)
print(f"Final dataset: {len(delays_all):,} stop-delay records")
print(f"Saved: {OUT_DIR / 'delays_all_routes_2025.parquet'}")


