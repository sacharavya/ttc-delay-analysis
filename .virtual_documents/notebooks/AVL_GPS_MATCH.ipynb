# ── Build a clean scheduled-stop lookup ────────────────────────────────────
# We need: trip_id, stop_id, stop_sequence, arrival_time (in seconds)
# This is the "what was scheduled" table we'll compare to AVL observations.

def hhmmss_to_sec(s: pd.Series) -> pd.Series:
    """Convert 'HH:MM:SS' (allows >24h for overnight trips) to seconds."""
    parts = s.str.split(":", expand=True).astype(float)
    return parts[0] * 3600 + parts[1] * 60 + parts[2]

gtfs_st["arrival_sec"]   = hhmmss_to_sec(gtfs_st["arrival_time"])
gtfs_st["departure_sec"] = hhmmss_to_sec(gtfs_st["departure_time"])
gtfs_st["stop_sequence"] = pd.to_numeric(gtfs_st["stop_sequence"], errors="coerce")

