import csv
from pathlib import Path

transsee_path = Path.home() / "Desktop" / "ttc-delay-analysis" / "data" / "raw" / "avl" / "trip_level" / "transsee.csv"
print(f"File size: {transsee_path.stat().st_size / 1e9:.2f} GB")

print("\\n=== First 3 rows ===")
with open(transsee_path, newline="", encoding="utf-8-sig") as f:
    reader = csv.reader(f)
    for i, row in enumerate(reader):
        print(f"Row {i}: {row}")
        if i >= 2:
            break


# ── For each AVL trip: find the GTFS trip on same route that starts closest ─
# AVL "trip start" = time of first ping on that trip_id
# GTFS "trip start" = departure_sec at stop_sequence = 1

# Step 1: AVL trip starts (route 29, Jan 1)
avl_trip_starts = (
    avl[(avl["route"] == "29") & (avl["date"] == "2025-01-01")]
    .groupby("trip_id")["time_sec"]
    .agg(first_ping="min", last_ping="max", n_pings="count")
    .reset_index()
)
print(f"AVL trips on Jan 1 route 29: {len(avl_trip_starts)}")

# Step 2: GTFS trip starts for active service on Jan 1
# active_sids already computed above = {'1'}
gtfs_starts = (
    gtfs_st[gtfs_st["trip_id"].isin(gtfs29_jan1_trip_ids)]
    .sort_values("stop_sequence")
    .groupby("trip_id")["departure_sec"]
    .first()
    .reset_index()
    .rename(columns={"departure_sec": "gtfs_start_sec"})
)
# Add direction from trips table
gtfs_starts = gtfs_starts.merge(
    gtfs_trips[["trip_id","direction_id","block_id","shape_id"]],
    on="trip_id", how="left"
)
print(f"GTFS trips on Jan 1 route 29: {len(gtfs_starts)}")

# Step 3: For each AVL trip, find nearest GTFS trip by start time
